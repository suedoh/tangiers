# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Machine role ──────────────────────────────────────────────────────────────
# PRIMARY controls whether this machine posts signals and responds to bot commands.
# Only one machine should be PRIMARY=true at a time to avoid duplicate Discord alerts.
#
#   Your machine (posts signals + runs bot):   PRIMARY=true
#   Friend's machine (TradingView only, silent): PRIMARY=false
#
# TRADINGVIEW_ENABLED controls whether to attempt CDP connection at all.
# Set to false on machines that don't have TradingView Desktop installed.
#
#   Has TradingView Desktop: TRADINGVIEW_ENABLED=true
#   No TradingView Desktop:  TRADINGVIEW_ENABLED=false
PRIMARY=true
TRADINGVIEW_ENABLED=true

# ── Discord Webhooks ──────────────────────────────────────────────────────────
# Create in: Discord Server Settings → Integrations → Webhooks → New Webhook

# #btc-signals channel — live trade alerts, invalidations, reclaims, errors
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# #btc-backtest channel — Monday weekly performance reports
# Naming convention: DISCORD_{INSTRUMENT}_BACKTEST_WEBHOOK_URL
# Add more instruments here as needed, e.g. DISCORD_ETH_BACKTEST_WEBHOOK_URL
DISCORD_BTC_BACKTEST_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# #btc-weekly-war-report channel — Sunday institutional preview
DISCORD_BTC_WEEKLY_WAR_REPORT=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# #general channel — !status command posts here (system briefing for new members)
DISCORD_HELPER=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Discord Bot (required for !analyze, !trades, emoji reactions, !status) ────
# Create at: discord.com/developers/applications → New Application → Bot → Reset Token
# Required permissions: Read Messages, Send Messages, Read Message History, Add Reactions
# No privileged intents required
DISCORD_BOT_TOKEN=your_bot_token_here

# The channel ID for #btc-signals
# To get it: right-click the channel in Discord → Copy Channel ID
# (Requires Developer Mode: Discord Settings → Advanced → Developer Mode)
DISCORD_CHANNEL_ID=your_channel_id_here

# ── BTC EW (Elliott Wave) Webhooks ────────────────────────────────────────────
# Three channels for the EW analysis layer.
# Convention: live EW posts share #btc-signals with trigger-check (separate
# webhook identity); backtest + report each get a dedicated channel.

# Live EW post webhook — separate webhook on the existing #btc-signals channel.
# Posts 6×/day scheduled EW analyses + on-demand !ew responses.
BTC_EW_SIGNALS_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# #btc-signals channel ID — bot listens here for !ew (alongside !analyze, !trades, etc.)
BTC_EW_SIGNALS_CHANNEL_ID=your_channel_id_here

# #btc-ew-backtest channel — cron-driven invalidation/target events + daily stats
BTC_EW_BACKTEST_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
BTC_EW_BACKTEST_CHANNEL_ID=your_channel_id_here

# #btc-ew-report channel — template-rendered daily brief (12:15 UTC),
# weekly outlook (Sunday 22:00 UTC), monthly cycle review (1st of month 14:00 UTC)
BTC_EW_REPORT_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
BTC_EW_REPORT_CHANNEL_ID=your_channel_id_here

# ── BZ! (Brent Crude) Webhooks ────────────────────────────────────────────────
# Create one webhook per channel in: Server Settings → Integrations → Webhooks

# #bz!-backtest channel — auto-logged signals + !took / !exit outcome tracking
BZ_DISCORD_BACKTEST_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# #bz!-weekly-war-report channel — Sunday 5pm ET institutional preview
BZ_DISCORD_WAR_REPORT_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# #bz!-signals channel — live alerts + !analyze manual trigger
BZ_DISCORD_SIGNALS_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── BZ! Bot Channel + News Monitoring ────────────────────────────────────────
# Channel IDs for all BZ! channels (right-click channel → Copy Channel ID)
BZ_DISCORD_SIGNALS_CHANNEL_ID=your_bz_signals_channel_id_here
BZ_DISCORD_WAR_REPORT_CHANNEL_ID=your_bz_weekly_war_report_channel_id_here
BZ_DISCORD_BACKTEST_CHANNEL_ID=your_bz_backtest_channel_id_here

# aisstream.io — free AIS WebSocket for tanker monitoring (Fujairah/Jebel Ali anchorages)
# Register at: aisstream.io — free tier, no credit card required
AISSTREAM_API_KEY=your_aisstream_api_key_here

# Anthropic API — Claude Haiku 4.5 sentiment classifier (fractions of a cent per call)
# Get key at: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TradingView layout IDs — from the URL bar when the layout is open:
#   tradingview.com/chart/LAYOUT_ID/
# BZ! layout: dedicated Brent crude chart (NYMEX:BZ1!, 4H, oil indicators)
# Ace layout: BTC layout (BINANCE:BTCUSDT.P)
BZ_LAYOUT_ID=your_bz_layout_id_here
ACE_LAYOUT_ID=your_ace_layout_id_here

# Geopolitical override — set to 'active' while Hormuz is closed/contested
# Activates: geo-premium scenarios in weekly report, elevated alert wording in signals
# Set back to 'inactive' when strait reopens
BZ_GEOPOLITICAL_FLAG=active

# ── Polymarket BTC 15-min ─────────────────────────────────────────────────────
# #poly-btc-15 channel — live directional signals (score ≥ 4/6)
POLY_BTC_15_SIGNALS_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# #poly-btc-15-report channel — Monday 09:00 UTC performance reports
POLY_BTC_15_REPORT_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Channel IDs for bot command polling (right-click channel → Copy Channel ID)
POLY_BTC_15_SIGNALS_CHANNEL_ID=your_poly_btc_15_signals_channel_id_here
POLY_BTC_15_REPORT_CHANNEL_ID=your_poly_btc_15_report_channel_id_here

# Current Polymarket market URL — update manually when the market rolls over
POLY_BTC_15_MARKET_URL=https://polymarket.com/event/will-btc-price-increase-in-15-minutes

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Strong random password for the MongoDB 'ace' user inside Docker.
# Generate one with: openssl rand -base64 32 | tr -d '=/+' | head -c 32
MONGO_PASSWORD=your_strong_mongo_password_here
# Connection string used by native cron scripts (host → Docker port-forward)
MONGO_URL=mongodb://ace:your_strong_mongo_password_here@127.0.0.1:27017/ace_trading?authSource=admin
